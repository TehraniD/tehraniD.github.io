      <!-- QUESTION 12: Tricky MC - Reverse calculation -->
      <item ident="q12" title="Q12: Unknown Identification">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
