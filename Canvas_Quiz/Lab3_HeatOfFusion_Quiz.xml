      <!-- Question 8: Multiple Choice - Difficulty 7 -->
      <item ident="q008" title="Specific Heat vs Heat of Fusion">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>5</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;A student has 50.0 g of ice at 0°C. Which process requires MORE energy?&lt;br&gt;&lt;br&gt;Process A: Melting all the ice at 0°C (ΔH&lt;sub&gt;f&lt;/sub&gt; = 334 J/g)&lt;br&gt;Process B: Heating the resulting liquid water from 0°C to 40°C (c = 4.184 J/g·°C)&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="A">
                <material>
                  <mattext texttype="text/html">Process A requires more energy (16,700 J vs 8,368 J)</mattext>
                </material>
              </response_label>
              <response_label ident="B">
                <material>
                  <mattext texttype="text/html">Process B requires more energy (20,920 J vs 16,700 J)</mattext>
                </material>
              </response_label>
              <response_label ident="C">
                <material>
                  <mattext texttype="text/html">Both processes require the same amount of energy</mattext>
                </material>
              </response_label>
              <response_label ident="D">
                <material>
                  <mattext texttype="text/html">Cannot be determined without knowing the final temperature</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="5" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">A</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">5</setvar>
          </respcondition>
        </resprocessing>
      </item>

