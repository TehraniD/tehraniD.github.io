      <!-- Question 6: Multiple Choice - Difficulty 7 -->
      <item ident="q006" title="Heat Loss Impact">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>multiple_choice_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>5</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;If significant heat is lost to the surroundings during the experiment, how will this affect the calculated value of ΔH&lt;sub&gt;f&lt;/sub&gt; compared to the theoretical value?&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="response1" rcardinality="Single">
            <render_choice>
              <response_label ident="A">
                <material>
                  <mattext texttype="text/html">ΔH&lt;sub&gt;f&lt;/sub&gt; will be too low because less energy appears to be absorbed by the ice</mattext>
                </material>
              </response_label>
              <response_label ident="B">
                <material>
                  <mattext texttype="text/html">ΔH&lt;sub&gt;f&lt;/sub&gt; will be too high because the water cools more than expected, making ΔT larger</mattext>
                </material>
              </response_label>
              <response_label ident="C">
                <material>
                  <mattext texttype="text/html">ΔH&lt;sub&gt;f&lt;/sub&gt; will not be affected because heat loss cancels out in the calculation</mattext>
                </material>
              </response_label>
              <response_label ident="D">
                <material>
                  <mattext texttype="text/html">ΔH&lt;sub&gt;f&lt;/sub&gt; will be too high only if the heat loss exceeds 10% of total energy</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="5" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="response1">B</varequal>
            </conditionvar>
            <setvar action="Set" varname="SCORE">5</setvar>
          </respcondition>
        </resprocessing>
      </item>

